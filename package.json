    "@react-three/drei": "^9.83.9",
    "@react-three/fiber": "^8.14.1",
    "@types/styled-components": "latest",
    "framer-motion": "^10.16.4",
    "gsap": "^3.11.3",
    "next": "latest",
    "next-themes": "^0.2.1",
    "raw-loader": "^4.0.2",
    "react": "latest",
    "react-dom": "latest",
    "react-merge-refs": "^2.0.2",
